.DS_Store

# Binaries for programs and plugins
*.exe
*.dll
*.so
*.dylib
/things-cli
/cmd/things-cli/things-cli
/cmd/thingsweb/thingsweb

# Test binary, build with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Project-local glide cache, RE: https://github.com/Masterminds/glide/issues/736
.glide/

# Environment files
*.env
.env
.env.*
/tmp/

# HAR files (may contain credentials)
*.har
docs/blog-post.md

# Fly.io config is deployment-specific and should not be committed
fly.toml

# Local Codex/Claude state
.claude/

# Generated by the shell test scripts
tests/test-results.log
